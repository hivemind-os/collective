{
  "name": "agentic-mesh",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.2",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test -- --run --passWithNoTests",
    "clean": "turbo run clean && rimraf node_modules .turbo packages/*/dist packages/*/.turbo packages/*/node_modules contracts/*/dist contracts/*/.turbo contracts/*/node_modules",
    "dev:sui": "powershell ./scripts/local-sui.ps1"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "@typescript-eslint/eslint-plugin": "^8.28.0",
    "@typescript-eslint/parser": "^8.28.0",
    "eslint": "^9.23.0",
    "eslint-config-prettier": "^10.1.1",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "tsup": "^8.4.0",
    "turbo": "^2.5.0",
    "typescript": "^5.8.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "keytar"
    ]
  }
}
