{
  "name": "@agentic-mesh/daemon",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js"
    },
    "./state": {
      "types": "./dist/state.d.ts",
      "import": "./dist/state.js"
    },
    "./provider": {
      "types": "./dist/provider/index.d.ts",
      "import": "./dist/provider/index.js"
    },
    "./ipc/server": {
      "types": "./dist/ipc/server.d.ts",
      "import": "./dist/ipc/server.js"
    }
  },
  "files": [
    "dist"
  ],
  "bin": {
    "mesh-daemon": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest",
    "lint": "eslint src/ tests/ vitest.config.ts tsup.config.ts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@agentic-mesh/core": "workspace:*",
    "@agentic-mesh/types": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@mysten/sui": "^1.30.0",
    "js-yaml": "^4.1.0",
    "pino": "^9.0.0",
    "pino-pretty": "^13.0.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
